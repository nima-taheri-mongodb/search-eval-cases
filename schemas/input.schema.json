{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "prompt": {
            "type": "string",
            "description": "The natural-language task sent to the agent for this case."
        },
        "db_seed": {
            "description": "Collections to seed into a fresh temp database before the agent runs.",
            "type": "array",
            "items": {
                "anyOf": [
                    {
                        "type": "string",
                        "description": "Bare collection name to seed with its bundled documents and no indexes."
                    },
                    {
                        "type": "object",
                        "propertyNames": {
                            "type": "string"
                        },
                        "additionalProperties": {
                            "type": "object",
                            "properties": {
                                "indexes": {
                                    "description": "Indexes to create after documents are inserted.",
                                    "type": "array",
                                    "items": {
                                        "oneOf": [
                                            {
                                                "type": "object",
                                                "properties": {
                                                    "type": {
                                                        "type": "string",
                                                        "enum": [
                                                            "search",
                                                            "vectorSearch"
                                                        ],
                                                        "description": "Index kind: 'search' for Atlas Search, 'vectorSearch' for vector search."
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "description": "Unique name of the search index. It is not optional because it is used to await readiness before querying."
                                                    },
                                                    "definition": {
                                                        "type": "object",
                                                        "propertyNames": {
                                                            "type": "string"
                                                        },
                                                        "additionalProperties": {},
                                                        "description": "Raw Atlas search index definition.\n\nFor more details, see the MongoDB Atlas Search documentation: https://www.mongodb.com/docs/manual/reference/command/createSearchIndexes/"
                                                    }
                                                },
                                                "required": [
                                                    "type",
                                                    "name",
                                                    "definition"
                                                ],
                                                "additionalProperties": false,
                                                "description": "An Atlas Search or Vector Search index to build on the collection."
                                            },
                                            {
                                                "type": "object",
                                                "properties": {
                                                    "type": {
                                                        "type": "string",
                                                        "const": "classic",
                                                        "description": "Marks this as a classic (non-search) MongoDB index."
                                                    },
                                                    "name": {
                                                        "description": "Optional index name; MongoDB auto-generates one when omitted.",
                                                        "type": "string"
                                                    },
                                                    "key": {
                                                        "type": "object",
                                                        "propertyNames": {
                                                            "type": "string"
                                                        },
                                                        "additionalProperties": {
                                                            "anyOf": [
                                                                {
                                                                    "type": "number",
                                                                    "const": 1
                                                                },
                                                                {
                                                                    "type": "number",
                                                                    "const": -1
                                                                }
                                                            ]
                                                        },
                                                        "description": "Index key spec mapping field name to sort order (1 ascending, -1 descending)."
                                                    }
                                                },
                                                "required": [
                                                    "type",
                                                    "key"
                                                ],
                                                "additionalProperties": {},
                                                "description": "A classic MongoDB index, plus any additional createIndex options."
                                            }
                                        ],
                                        "description": "A single index to create on a seeded collection, discriminated by 'type'."
                                    }
                                }
                            },
                            "additionalProperties": false,
                            "description": "Setup applied to a seeded collection (currently just its indexes)."
                        },
                        "description": "Single-key object mapping a collection name to its seeding setup."
                    }
                ],
                "description": "A collection to seed, optionally with index setup."
            }
        }
    },
    "required": [
        "prompt"
    ],
    "additionalProperties": false,
    "description": "Input for a single MongoDB agent eval case.",
    "$id": "https://mongodb-eval-cases/schemas/input.schema.json"
}
